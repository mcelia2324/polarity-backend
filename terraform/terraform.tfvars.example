project_id  = "polarity-488001"
region      = "us-east1"
environment = "prod"

app_timezone = "America/Chicago"
send_hour    = 8
send_minute  = 0

apns_bundle_id = "mcelia.PolarityApp"

# Set sensitive values via environment variables:
#   export TF_VAR_db_password="..."
#   export TF_VAR_openai_api_key="..."
